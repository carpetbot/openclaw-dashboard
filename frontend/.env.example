# OpenClaw Dashboard Frontend Environment Variables
# Copy this to .env and update with your tunnel URL

# WebSocket URL for the bridge (use wss:// for production)
VITE_BRIDGE_URL=ws://localhost:3001/ws

# HTTP URL for the bridge (REST API fallback)
VITE_BRIDGE_HTTP=http://localhost:3001

# For production with Cloudflare Tunnel:
# VITE_BRIDGE_URL=wss://openclaw-bridge.yourdomain.com/ws
# VITE_BRIDGE_HTTP=https://openclaw-bridge.yourdomain.com
